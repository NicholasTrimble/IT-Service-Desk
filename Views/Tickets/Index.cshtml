@model IEnumerable<IT_Service_Desk.Models.Ticket>

@{
    ViewData["Title"] = "Service Dashboard";
}

@* 1. Header Section *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary fw-bold mb-0">Service Dashboard</h1>
    <a asp-action="Create" class="btn btn-primary shadow">
        <i class="bi bi-plus-lg"></i> New Ticket
    </a>
</div>

@* 2. Statistics Cards *@
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-dark text-white border-primary border-opacity-25 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold">Total Tickets</h6>
                <p class="display-6 mb-0">@Model.Count()</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white border-success border-opacity-25 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small fw-bold">Open Tickets</h6>
                <p class="display-6 mb-0 text-success">@Model.Count(t => t.Status == IT_Service_Desk.Models.TicketStatus.Open)</p>
            </div>
        </div>
    </div>
</div>

@* 3. Filter Section *@
<form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end p-3 bg-dark rounded border border-secondary border-opacity-25 mx-0">
    <div class="col-md-4">
        <label class="form-label text-muted small fw-bold">Search Keywords</label>
        <div class="input-group">
            <span class="input-group-text bg-transparent border-secondary border-opacity-50 text-muted">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" name="searchString" class="form-control bg-transparent border-secondary border-opacity-50 text-white" placeholder="Title, description..." value="@Context.Request.Query["searchString"]" />
        </div>
    </div>
    <div class="col-md-3">
        <label class="form-label text-muted small fw-bold">Status Filter</label>
        <select name="statusFilter" class="form-select bg-transparent border-secondary border-opacity-50 text-white" asp-items="Html.GetEnumSelectList<IT_Service_Desk.Models.TicketStatus>()">
            <option value="">All Statuses</option>
        </select>
    </div>
    <div class="col-md-5 d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4 flex-grow-1">
            Apply Filters
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary px-3">
            Clear
        </a>
    </div>
</form>

@* 4. The Main Table *@
<div class="table-responsive bg-dark rounded border border-secondary border-opacity-25 shadow-sm">
    <table class="table table-dark table-hover align-middle mb-0">
        <thead class="bg-black bg-opacity-25 text-muted small text-uppercase">
            <tr>
                <th class="ps-4">@Html.DisplayNameFor(model => model.Title)</th>
                <th>Status</th>
                <th>Priority</th>
                <th>Assigned To</th>
                <th>Created</th>
                <th class="text-end pe-4">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-4">
                        <div class="fw-bold text-white">@item.Title</div>
                        <div class="small text-muted text-truncate" style="max-width: 250px;">@item.Description</div>
                    </td>
                    <td>
                        @{
                            var statusClass = item.Status switch
                            {
                                IT_Service_Desk.Models.TicketStatus.Open => "border-success text-success",
                                IT_Service_Desk.Models.TicketStatus.InProgress => "border-primary text-primary",
                                _ => "border-secondary text-secondary"
                            };
                        }
                        <span class="badge border @statusClass fw-normal">@item.Status</span>
                    </td>
                    <td>
                        @{
                            var priorityClass = item.Priority switch
                            {
                                IT_Service_Desk.Models.TicketPriority.Urgent => "bg-danger",
                                IT_Service_Desk.Models.TicketPriority.High => "bg-warning text-dark",
                                IT_Service_Desk.Models.TicketPriority.Medium => "bg-info text-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @priorityClass">@item.Priority</span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-circle text-muted me-2"></i>
                            <span class="@(item.AssignedTo == "Unassigned" ? "text-muted italic" : "text-light")">@item.AssignedTo</span>
                        </div>
                    </td>
                    <td class="small text-muted">
                        @item.CreatedAt.ToString("MM/dd/yy")
                    </td>
                    <td class="text-end pe-4">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edit
                            </a>

                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i> View
                            </a>

                            @if (item.AssignedTo == "Unassigned")
                            {
                                <form asp-action="Claim" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-person-plus"></i> Claim
                                    </button>
                                </form>
                            }

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>