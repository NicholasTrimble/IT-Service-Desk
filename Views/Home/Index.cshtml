@{
    ViewData["Title"] = "AssetOperations";
}

<div class="container mt-5">
    <div class="row align-items-center g-5">
        @* Left Column: Branding & Value Proposition *@
        <div class="col-lg-6">
            <div class="badge bg-primary mb-3">v1.0 Operational</div>
            <h1 class="display-4 fw-bold text-white">A Asset Management Hub</h1>
            <p class="lead mt-3 text-secondary">
                A high-performance operational platform built to track asset lifecycles, maintenance schedules, and team productivity.
            </p>
            
            <ul class="list-unstyled mt-4 text-light">
                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Asset Lifecycle Management:</strong> Track equipment from deployment to decommission.</li>
                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Preventative Scheduling:</strong> Proactive maintenance workflows.</li>
                <li class="mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i><strong>Data-Driven KPIs:</strong> Real-time operational visibility.</li>
            </ul>

            <div class="mt-4">
                <a asp-controller="WorkOrders" asp-action="Index" class="btn btn-primary btn-lg px-4 shadow">
                    Go to Dashboard
                </a>
            </div>
        </div>

        @* Right Column: Visual Component *@
        <div class="col-lg-6">
            <div class="position-relative">
                <a asp-controller="WorkOrders" asp-action="Index" class="text-decoration-none">
                    <img src="/images/WorkOrdersboard.png" class="img-fluid rounded shadow-lg border border-secondary" alt="Go to WorkOrders" />
                    
                    @* The "Live Demo" Badge moved inside the image container to prevent layout breaking *@
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow">
                        Live Demo
                    </span>
                </a>
            </div>
        </div>
    </div>
</div>