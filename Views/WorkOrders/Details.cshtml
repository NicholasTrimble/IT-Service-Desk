@model IT_Service_Desk.Models.WorkOrder

@{
    ViewData["Title"] = "Work Order Details";
}

<div class="container py-4">
    <div class="card shadow-lg bg-dark text-white border-secondary">
        <div class="card-header border-secondary d-flex justify-content-between align-items-center">
            <h2 class="mb-0">AssetOps #@Model.Id: @Model.Title</h2>
            <span class="badge bg-primary">@Model.Status</span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <h5 class="text-secondary text-uppercase small fw-bold">Description</h5>
                    <p class="lead">@Model.Description</p>
                </div>
                <div class="col-md-4 border-start border-secondary">
                    <ul class="list-unstyled">
                        <li class="mb-3"><strong>Priority:</strong> <span class="badge bg-info">@Model.Urgency</span></li>
                        <li class="mb-3"><strong>Created By:</strong> <span class="text-muted">@Model.CreatedBy</span></li>
                        <li class="mb-3"><strong>Assigned To:</strong> <span class="text-secondary">@Model.AssignedTo</span></li>
                        <li class="mb-3"><strong>Date Created:</strong> <span class="text-muted">@Model.CreatedAt.ToString("MMM dd, yyyy")</span></li>
                    </ul>
                </div>
            </div>

            <hr class="border-secondary my-4" />

            @* Operational Audit Log Section *@
            <h5 class="text-secondary text-uppercase small fw-bold mb-3">Operational History</h5>
            <div class="table-responsive">
                <table class="table table-dark table-hover table-sm">
                    <thead>
                        <tr class="text-muted small">
                            <th>Action</th>
                            <th>Timestamp</th>
                            <th>User</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.AuditLogs.OrderByDescending(l => l.Timestamp))
                        {
                            <tr>
                                <td>@log.Action</td>
                                <td>@log.Timestamp.ToString("g")</td>
                                <td>@log.ChangedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-3 mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">Edit WorkOrder</a>
                <form asp-action="Claim" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-success">Claim WorkOrder</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
            </div>
        </div>
    </div>
</div>